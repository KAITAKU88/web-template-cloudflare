# ==========================================================
# BẮT BUỘC — Cần set trước khi deploy (không thể cấu hình qua Dashboard)
# ==========================================================

# Supabase (Dashboard → Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable__...   # Publishable key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...             # Secret key

# Database password (chỉ dùng cho CLI push, KHÔNG commit)
SUPABASE_DB_PASSWORD=your-database-password

# Admin Dashboard — THAY ĐỔI trước khi go-live
ADMIN_PASSWORD=your-strong-admin-password           # Mật khẩu đăng nhập /admin
ADMIN_SECRET=your-random-secret-string             # HMAC signing secret (random 32+ ký tự)

# Cron job (Netlify Scheduled Functions)
CRON_SECRET=your-random-cron-secret

# ==========================================================
# TÙY CHỌN — Có thể cấu hình qua Admin Dashboard thay vì env
# (Nếu set cả hai, Dashboard ưu tiên hơn env var)
# ==========================================================

# Tài khoản ngân hàng — cấu hình được qua Dashboard → Thanh toán
# Tra cứu BANK_CODE tại: https://api.vietqr.io/v2/banks
BANK_CODE=MB                          # VD: MB, VCB, TCB, ACB, ...
BANK_ACCOUNT_NUMBER=1234567890        # Số tài khoản ngân hàng

# SePay — cấu hình được qua Dashboard → Thanh toán
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret

# Supabase Database Webhook — cấu hình được qua Dashboard → Cấu hình nâng cao
SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret

# Email (Resend) — cấu hình được qua Dashboard → Email
# RESEND_API_KEY=re_...
# RESEND_FROM=YourBrand <no-reply@yourdomain.com>

# Google Analytics 4 — cấu hình được qua Dashboard → Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
